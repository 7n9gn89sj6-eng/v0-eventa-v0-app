{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eventa-search-eval-review-record",
  "title": "Human review for one evaluation query run",
  "type": "object",
  "required": ["queryId", "runId", "top5", "scores"],
  "properties": {
    "queryId": { "type": "string" },
    "runId": { "type": "string", "description": "ISO timestamp or git sha + timestamp" },
    "top5": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["rank", "source", "title", "urlOrId"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "source": { "enum": ["internal", "web"] },
          "title": { "type": "string" },
          "urlOrId": { "type": "string" },
          "city": { "type": "string" },
          "startAt": { "type": ["string", "null"] },
          "genericWebPenalty": { "type": ["number", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "mix": {
      "type": "object",
      "properties": {
        "internalReturned": { "type": "integer" },
        "webReturned": { "type": "integer" },
        "top5Internal": { "type": "integer" },
        "top5Web": { "type": "integer" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["exactness", "geoAccuracy", "timeRelevance", "hubNoise"],
      "properties": {
        "exactness": { "type": "integer", "minimum": 1, "maximum": 5 },
        "geoAccuracy": { "type": "integer", "minimum": 1, "maximum": 5 },
        "timeRelevance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "hubNoise": { "type": "integer", "minimum": 1, "maximum": 5, "description": "5 = clean; 1 = heavy directory/hub contamination" }
      }
    },
    "reviewerNotes": { "type": "string" }
  }
}
