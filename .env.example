# Optional: event poster uploads (Cloudflare R2, S3-compatible API). When all vars below are set, POST /api/events/event-image
# accepts multipart `file` from /create-simple and returns { url }. Use an API token with Object Read & Write on the bucket.
# Expose objects at R2_PUBLIC_BASE_URL (R2 public bucket URL, custom domain, or worker — must be https, no trailing slash).
# R2_ACCOUNT_ID="your_cloudflare_account_id"
# R2_ACCESS_KEY_ID="your_r2_api_token_access_key"
# R2_SECRET_ACCESS_KEY="your_r2_api_token_secret"
# R2_BUCKET_NAME="your_bucket_name"
# R2_PUBLIC_BASE_URL="https://pub-xxxxx.r2.dev"
